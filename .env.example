# Copy to .env and fill in. NEVER commit .env.

# LLM provider. Default is "ollama" (local, free — run `ollama serve` with qwen3:8b
# pulled; no key needed, no data leaves the machine). Set to "anthropic" for Claude.
NAUSICA_LLM_PROVIDER=ollama

# Only required if NAUSICA_LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Optional: only if you switch any module to an OpenAI model in configs/
OPENAI_API_KEY=

# Optional: HuggingFace token — required to download the gated
# mental/mental-roberta-base checkpoint (accept its terms on the Hub first)
HF_TOKEN=

# --- Persistence & auth (Phase 3) ---

# Postgres connection. Defaults to the local Homebrew instance if unset.
# docker-compose alternative: postgresql+psycopg://nausica:nausica@localhost:5432/nausica
DATABASE_URL=postgresql+psycopg://localhost/nausica

# JWT signing secret — REQUIRED outside local dev (generate: openssl rand -hex 32).
# Without it the server uses an insecure dev secret and logs a warning.
NAUSICA_JWT_SECRET=
